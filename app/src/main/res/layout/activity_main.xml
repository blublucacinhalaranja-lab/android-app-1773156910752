<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/displayTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="36sp"
        android:gravity="end"
        android:padding="16dp"
        android:background="@color/calculator_display_background"
        android:textColor="@color/calculator_display_text"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="0" />

    <GridLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:columnCount="4"
        android:rowCount="5"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/displayTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/buttonClear"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="C"
            android:textSize="24sp"
            android:backgroundTint="@color/operation_button_background"
            android:textColor="@color/operation_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/buttonPlusMinus"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="+/-"
            android:textSize="24sp"
            android:backgroundTint="@color/operation_button_background"
            android:textColor="@color/operation_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/buttonPercent"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="%"
            android:textSize="24sp"
            android:backgroundTint="@color/operation_button_background"
            android:textColor="@color/operation_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/buttonDivide"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="/"
            android:textSize="24sp"
            android:backgroundTint="@color/operation_button_background"
            android:textColor="@color/operation_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/button7"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="7"
            android:textSize="24sp"
            android:backgroundTint="@color/calculator_button_background"
            android:textColor="@color/calculator_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/button8"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="8"
            android:textSize="24sp"
            android:backgroundTint="@color/calculator_button_background"
            android:textColor="@color/calculator_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/button9"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="9"
            android:textSize="24sp"
            android:backgroundTint="@color/calculator_button_background"
            android:textColor="@color/calculator_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/buttonMultiply"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="*"
            android:textSize="24sp"
            android:backgroundTint="@color/operation_button_background"
            android:textColor="@color/operation_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/button4"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="4"
            android:textSize="24sp"
            android:backgroundTint="@color/calculator_button_background"
            android:textColor="@color/calculator_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/button5"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="5"
            android:textSize="24sp"
            android:backgroundTint="@color/calculator_button_background"
            android:textColor="@color/calculator_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/button6"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="6"
            android:textSize="24sp"
            android:backgroundTint="@color/calculator_button_background"
            android:textColor="@color/calculator_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/buttonMinus"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="-"
            android:textSize="24sp"
            android:backgroundTint="@color/operation_button_background"
            android:textColor="@color/operation_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/button1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="1"
            android:textSize="24sp"
            android:backgroundTint="@color/calculator_button_background"
            android:textColor="@color/calculator_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/button2"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="2"
            android:textSize="24sp"
            android:backgroundTint="@color/calculator_button_background"
            android:textColor="@color/calculator_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/button3"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="3"
            android:textSize="24sp"
            android:backgroundTint="@color/calculator_button_background"
            android:textColor="@color/calculator_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/buttonPlus"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="+"
            android:textSize="24sp"
            android:backgroundTint="@color/operation_button_background"
            android:textColor="@color/operation_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/button0"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="0"
            android:textSize="24sp"
            android:backgroundTint="@color/calculator_button_background"
            android:textColor="@color/calculator_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/buttonDecimal"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="."
            android:textSize="24sp"
            android:backgroundTint="@color/calculator_button_background"
            android:textColor="@color/calculator_button_text"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/buttonEquals"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="2"
            android:layout_rowWeight="1"
            android:text="="
            android:textSize="24sp"
            android:backgroundTint="@color/equal_button_background"
            android:textColor="@color/equal_button_text"
            android:layout_margin="2dp"
            android:layout_columnSpan="2"/>

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>